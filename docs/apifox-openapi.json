                  "gate1_opening_after": { "type": "number" },
                  "gate2_opening_after": { "type": "number" },
                  "gate3_opening_after": { "type": "number" },
                  "action_detail": { "type": "object" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "ok" } }
      }
    },
    "/api/v1/settings/gate-interlock/rules": {
      "get": {
        "tags": ["闸门互锁"],
        "summary": "§13.1 互锁规则列表",
        "description": "返回全局默认 + 指定水库专属规则，按 priority 排序",
        "parameters": [
          { "name": "reservoir_id", "in": "query", "schema": { "type": "integer" }, "description": "不传仅返回全局默认规则" }
        ],
        "responses": { "200": { "description": "ok" } }
      }
    },
    "/api/v1/settings/gate-interlock/rules/{id}": {
      "put": {
        "tags": ["闸门互锁"],
        "summary": "§13.2 更新互锁规则",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "rule_name": { "type": "string" },
                  "description": { "type": "string" },
                  "enabled": { "type": "boolean" },
                  "priority": { "type": "integer" },
                  "trigger_conditions": { "type": "object" },
                  "constraint_action": { "type": "object" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "ok" } }
      }
    },
    "/api/v1/settings/gate-interlock/rules/{id}/toggle": {
      "post": {
        "tags": ["闸门互锁"],
        "summary": "§13.3 启用/禁用规则",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["enabled"],
                "properties": {
                  "enabled": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "ok" } }
      }
    },
    "/api/v1/settings/gate-interlock/logs": {
      "get": {
        "tags": ["闸门互锁"],
        "summary": "§13.4 互锁触发日志",
        "description": "查询互锁规则触发历史，支持按水库/规则/时间筛选",
        "parameters": [
          { "name": "reservoir_id", "in": "query", "schema": { "type": "integer" } },
          { "name": "rule_id", "in": "query", "schema": { "type": "integer" } },
          { "name": "start_time", "in": "query", "schema": { "type": "string" } },
          { "name": "end_time", "in": "query", "schema": { "type": "string" } },
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "page_size", "in": "query", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": { "200": { "description": "ok" } }
      }
    },
    "/api/v1/settings/gate-interlock/stats": {
      "get": {
        "tags": ["闸门互锁"],
        "summary": "§13.5 互锁触发统计",
        "parameters": [
          { "name": "reservoir_id", "in": "query", "schema": { "type": "integer" } },
          { "name": "days", "in": "query", "schema": { "type": "integer", "default": 7 } }
        ],
        "responses": { "200": { "description": "返回各规则触发次数" } }
      }
    }
  }
}
