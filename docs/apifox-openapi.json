{
  "openapi": "3.0.3",
  "info": {
    "title": "水电站闸门智能调度系统 API",
    "version": "v2.4",
    "description": "告警管理 / 调度决策 / 水库管理 / 边缘节点管理 / 数字孪生 / 边缘端上报 / 边缘端配置下发 / 闸门互锁"
  },
  "servers": [
    { "url": "http://47.108.169.152:4088", "description": "生产环境" },
    { "url": "http://h63d7bc8.natappfree.cc", "description": "开发环境(natapp隧道)" },
    { "url": "http://localhost:8000", "description": "本机后端" }
  ],
  "security": [{ "BearerAuth": [] }],
  "components": {
    "securitySchemes": {
      "BearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    },
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "integer", "description": "0=成功" },
          "msg": { "type": "string" },
          "data": {},
          "success": { "type": "boolean" },
          "trace_id": { "type": "string" }
        }
      },
      "PageResult": {
        "type": "object",
        "properties": {
          "total": { "type": "integer" },
          "list": { "type": "array", "items": {} }
        }
      },
      "AlarmRecord": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "alarm_no": { "type": "string", "description": "告警编号" },
          "equipment_id": { "type": "integer" },
          "equipment_name": { "type": "string" },
          "type": { "type": "string", "enum": ["water_level","flow","gate","power","equipment","physics_violation","comm_loss"] },
          "level": { "type": "string", "enum": ["urgent","important","normal"] },
          "message": { "type": "string", "description": "告警描述" },
          "metric_value": { "type": "number" },
          "threshold_value": { "type": "number" },
          "status": { "type": "string", "enum": ["unhandled","acknowledged","disposed"] },
          "created_at": { "type": "string" }
        }
      },
      "EdgeNodeItem": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "code": { "type": "string" },
          "reservoir_id": { "type": "integer" },
          "reservoir_name": { "type": "string" },
          "status": { "type": "string", "enum": ["online","offline","fault"] },
          "ip": { "type": "string" },
          "last_heartbeat": { "type": "string" },
          "cpu_usage": { "type": "number" },
          "memory_usage": { "type": "number" },
          "model_version": { "type": "string" },
          "autonomy_mode": { "type": "integer" }
        }
      },
      "DispatchDecision": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "trace_id": { "type": "string" },
          "reservoir_id": { "type": "integer" },
          "decision_time": { "type": "string" },
          "decision_mode": { "type": "string", "enum": ["L1","L2","L3"] },
          "risk_rank": { "type": "integer", "enum": [1,2,3] },
          "recommended_opening": { "type": "number" },
          "confidence": { "type": "number" },
          "execution_status": { "type": "string", "enum": ["pending","executed","rejected","failed"] },
          "physics_validation": { "type": "object" }
        }
      },
      "SimulationScenario": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["production","energy","fault"] },
          "status": { "type": "string", "enum": ["active","inactive","draft"] },
          "description": { "type": "string" },
          "model_id": { "type": "integer" }
        }
      },
      "EdgeMonitoringReport": {
        "type": "object",
        "required": ["reservoir_id","edge_node_id","data"],
        "properties": {
          "reservoir_id": { "type": "integer" },
          "edge_node_id": { "type": "integer" },
          "data": {
            "type": "array",
            "maxItems": 1000,
            "items": {
              "type": "object",
              "properties": {
                "timestamp": { "type": "string" },
                "upstream_level": { "type": "number" },
                "downstream_level": { "type": "number" },
                "water_head": { "type": "number" },
                "inflow_rate": { "type": "number" },
                "outflow_rate": { "type": "number" },
                "gate_opening": { "type": "number" },
                "power_output": { "type": "number" },
                "cumulative_energy": { "type": "number" }
              }
            }
          }
        }
      },
      "PhysicsGuardConfig": {
        "type": "object",
        "properties": {
          "reservoir_id": { "type": "integer" },
          "config_version": { "type": "string" },
          "is_active": { "type": "boolean" },
          "upstream_danger": { "type": "number" },
          "upstream_emergency": { "type": "number" },
          "upstream_warning": { "type": "number" },
          "fusion_l3_confidence": { "type": "number" },
          "fusion_l3_risk": { "type": "number" }
        }
      }
    }
  },
  "tags": [
    { "name": "告警管理", "description": "§3 告警管理模块 — Wjc 负责" },
    { "name": "调度决策", "description": "§4 调度决策模块 — Wjc 负责" },
    { "name": "水库管理", "description": "§5 水库管理模块 — Wjc 负责" },
    { "name": "边缘节点管理", "description": "§6 边缘节点管理模块 — Wjc 负责" },
    { "name": "数字孪生", "description": "§9 数字孪生模块 — LX 负责" },
    { "name": "边缘端上报", "description": "§11 边缘端数据上报接口 — LX 负责" },
    { "name": "边缘端配置下发", "description": "§12 物理配置 + §8.3.6 模型下发 — 边缘端配置管理" },
    { "name": "闸门互锁", "description": "§13 闸门互锁规则模块 — Wjc 负责" }
  ],
  "paths": {
    "/api/v1/alarms": {
      "get": {
        "tags": ["告警管理"],
        "summary": "§3.1 正式告警分页列表",
        "description": "数据来源 alarms 表，关联 equipment 获取设备名称",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "page_size", "in": "query", "schema": { "type": "integer", "default": 20 } },
          { "name": "reservoir_id", "in": "query", "schema": { "type": "integer" } },
          { "name": "level", "in": "query", "schema": { "type": "string", "enum": ["urgent","important","normal"] } },
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["unhandled","acknowledged","disposed"] } },
          { "name": "type", "in": "query", "schema": { "type": "string" } },
          { "name": "start_time", "in": "query", "schema": { "type": "string" } },
          { "name": "end_time", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "ok" }
        }
      }
    },
    "/api/v1/alarms/{id}/acknowledge": {
      "put": {
        "tags": ["告警管理"],
        "summary": "§3.2 确认告警",
        "description": "更新 alarms.status = 'acknowledged'，记录确认人",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "ok" }
        }
      }
    },
    "/api/v1/alarms/{id}/dispose": {
      "put": {
        "tags": ["告警管理"],
        "summary": "§3.3 处置告警",
        "description": "更新 alarms.status = 'disposed'，写入处置备注",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["dispose_note"],
                "properties": {
                  "dispose_note": { "type": "string", "description": "处置备注，10~500字" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "ok" }
        }
      }
    },
    "/api/v1/alarms/exceed-logs": {
      "get": {
        "tags": ["告警管理"],
        "summary": "§3.4 瞬时超限日志",
        "description": "记录 < 30s 的瞬时超限，数据来源 alarm_exceed_logs 表",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "page_size", "in": "query", "schema": { "type": "integer" } },
          { "name": "equipment_id", "in": "query", "schema": { "type": "integer" } },
          { "name": "metric", "in": "query", "schema": { "type": "string" } },
          { "name": "start_time", "in": "query", "schema": { "type": "string" } },
          { "name": "end_time", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "ok" }
        }
      }
    },
    "/api/v1/alarms/{id}": {
      "get": {
        "tags": ["告警管理"],
        "summary": "告警详情（补充接口）",
        "description": "查询单条告警完整信息。需求来源：前端WarningPage告警详情弹窗",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "返回 AlarmRecord 完整字段" } }
      }
    },
    "/api/v1/dispatch/predictions": {
      "get": {
        "tags": ["调度决策"],
        "summary": "§4.1 获取 LSTM 预测数据",
        "parameters": [
          { "name": "reservoir_id", "in": "query", "required": true, "schema": { "type": "integer" } },
          { "name": "predict_term", "in": "query", "required": true, "schema": { "type": "integer", "enum": [1,2,3], "description": "1=1h 2=3h 3=6h" } }
        ],
        "responses": { "200": { "description": "ok" } }
      }
    },
    "/api/v1/dispatch/decisions": {
      "get": {
        "tags": ["调度决策"],
        "summary": "§4.3 调度决策历史列表",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "page_size", "in": "query", "schema": { "type": "integer" } },
          { "name": "reservoir_id", "in": "query", "schema": { "type": "integer" } },
          { "name": "decision_mode", "in": "query", "schema": { "type": "string", "enum": ["L1","L2","L3"] } },
          { "name": "execution_status", "in": "query", "schema": { "type": "string", "enum": ["pending","executed","rejected","failed"] } },
          { "name": "start_time", "in": "query", "schema": { "type": "string" } },
          { "name": "end_time", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "ok" } }
      }
    },
    "/api/v1/dispatch/decisions/{id}": {
      "get": {
        "tags": ["调度决策"],
        "summary": "§4.2 AI 决策详情",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "ok" } }
      }
    },
    "/api/v1/dispatch/execute": {
      "post": {
        "tags": ["调度决策"],
        "summary": "§4.4 人工下发调度指令",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["reservoir_id","target_opening"],
                "properties": {
                  "reservoir_id": { "type": "integer" },
                  "decision_id": { "type": "integer", "description": "关联AI决策ID，纯手动则不传" },
                  "target_opening": { "type": "number", "description": "目标闸门开度(%)" },
                  "operate_note": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "返回 command_id" } }
      }
    },
    "/api/v1/dispatch/commands/{command_id}/trace": {
      "get": {
        "tags": ["调度决策"],
        "summary": "§4.5 指令全链路追踪",
        "description": "查询 云端→边缘→PLC 完整链路",
        "parameters": [
          { "name": "command_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "ok" } }
      }
    },
    "/api/v1/dispatch/gate-actions": {
      "get": {
        "tags": ["调度决策"],
        "summary": "§4.6 闸门动作历史",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "page_size", "in": "query", "schema": { "type": "integer" } },
          { "name": "equipment_id", "in": "query", "schema": { "type": "integer" } },
          { "name": "action_type", "in": "query", "schema": { "type": "string", "enum": ["open","close","maintain","emergency"] } },
          { "name": "start_time", "in": "query", "schema": { "type": "string" } },
          { "name": "end_time", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "ok" } }
      }
    },
    "/api/v1/dispatch/emergency-stop": {
      "post": {
        "tags": ["调度决策"],
        "summary": "§4.7 全局急停",
        "description": "最高优先级指令，写入 emergency_stops、control_commands 表",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["reservoir_id","stop_reason"],
                "properties": {
                  "reservoir_id": { "type": "integer" },
                  "stop_reason": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "返回 stop_log_id + command_id" } }
      }
    },
    "/api/v1/dispatch/stop-recover/{id}": {
      "put": {
        "tags": ["调度决策"],
        "summary": "§4.8 恢复闸门自动模式",
        "description": "更新 emergency_stops.recover_time，解除急停锁定",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "ok" } }
      }
    },
    "/api/v1/dispatch/emergency-stops": {
      "get": {
        "tags": ["调度决策"],
        "summary": "§4.9 急停日志列表",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "page_size", "in": "query", "schema": { "type": "integer" } },
          { "name": "reservoir_id", "in": "query", "schema": { "type": "integer" } },
          { "name": "start_time", "in": "query", "schema": { "type": "string" } },
          { "name": "end_time", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "ok" } }
      }
    },
    "/api/v1/reservoirs": {
      "get": {
        "tags": ["水库管理"],
        "summary": "§5.1 水库列表",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "page_size", "in": "query", "schema": { "type": "integer", "default": 20 } },
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["active","inactive","maintenance"] } },
          { "name": "keyword", "in": "query", "schema": { "type": "string", "description": "名称/编码关键字搜索" } }
        ],
        "responses": { "200": { "description": "ok" } }
      },
      "post": {
        "tags": ["水库管理"],
        "summary": "§5.3 新增水库",
        "description": "role.admin",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name","code","type","dead_water_level","normal_water_level","flood_limit_level","design_flood_level","check_flood_level","total_capacity","ecological_flow"],
                "properties": {
                  "name": { "type": "string" },
                  "code": { "type": "string", "description": "水库编码，唯一" },
                  "type": { "type": "string", "enum": ["daily_regulation","seasonal","multi_year"] },
                  "dead_water_level": { "type": "number" },
                  "normal_water_level": { "type": "number" },
                  "flood_limit_level": { "type": "number" },
                  "design_flood_level": { "type": "number" },
                  "check_flood_level": { "type": "number" },
                  "total_capacity": { "type": "number" },
                  "installed_capacity": { "type": "number" },
                  "ecological_flow": { "type": "number" },
                  "location_lat": { "type": "number" },
                  "location_lng": { "type": "number" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "ok" } }
      }
    },
    "/api/reservoirs/{id}": {
      "get": {
        "tags": ["水库管理"],
        "summary": "§5.2 水库详情",
        "description": "返回 reservoirs 表全部字段 + 关联节点数 + 设备数。注意：无 v1 前缀",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "ok" } }
      }
    },
    "/api/v1/reservoirs/{id}": {
      "put": {
        "tags": ["水库管理"],
        "summary": "§5.4 更新水库",
        "description": "role.admin。全部字段可选",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "ok" } }
      },
      "delete": {
        "tags": ["水库管理"],
        "summary": "§5.5 删除水库",
        "description": "软删除，role.admin。关联有设备/节点时返回 30006",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "ok" } }
      }
    },
    "/api/v1/edge-nodes": {
      "get": {
        "tags": ["边缘节点管理"],
        "summary": "§6.1 边缘节点列表",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "page_size", "in": "query", "schema": { "type": "integer" } },
          { "name": "reservoir_id", "in": "query", "schema": { "type": "integer" } },
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["online","offline","fault"] } }
        ],
        "responses": { "200": { "description": "ok" } }
      },
      "post": {
        "tags": ["边缘节点管理"],
        "summary": "§6.3 注册边缘节点",
        "description": "role.admin",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name","code","reservoir_id"],
                "properties": {
                  "name": { "type": "string" },
                  "code": { "type": "string", "description": "节点编号，唯一" },
                  "reservoir_id": { "type": "integer" },
                  "location": { "type": "string" },
                  "ip": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "ok" } }
      }
    },
    "/api/v1/edge-nodes/{id}": {
      "get": {
        "tags": ["边缘节点管理"],
        "summary": "§6.2 边缘节点详情",
        "description": "含关联设备列表",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "ok" } }
      },
      "delete": {
        "tags": ["边缘节点管理"],
        "summary": "§6.5 删除边缘节点",
        "description": "软删除，role.admin；关联有设备时返回 30006",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "ok" } }
      }
    },
    "/api/v1/edge-nodes/{id}/heartbeat": {
      "post": {
        "tags": ["边缘节点管理"],
        "summary": "§6.4 心跳上报",
        "description": "边缘端每30s调用一次，更新运行状态",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["status"],
                "properties": {
                  "status": { "type": "string", "enum": ["online","fault"] },
                  "cpu_usage": { "type": "number" },
                  "memory_usage": { "type": "number" },
                  "disk_usage": { "type": "number" },
                  "plc_status": { "type": "string" },
                  "autonomy_mode": { "type": "integer" },
                  "cache_size": { "type": "integer" },
                  "model_version": { "type": "string" },
                  "threshold_version": { "type": "string" },
                  "weight_version": { "type": "string" },
                  "physics_config_version": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "ok" } }
      }
    },
    "/api/simulation/scenarios": {
      "get": {
        "tags": ["数字孪生"],
        "summary": "§9.1 获取仿真场景列表",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "page_size", "in": "query", "schema": { "type": "integer" } },
