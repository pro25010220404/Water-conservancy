# 复制为 .env.development 或 .env.production 后按需修改

# API 根路径（开发环境建议 /api + vite 代理；生产填完整地址如 http://host:port/api）
VITE_API_BASE_URL=/api

# v1 接口前缀（告警等：GET {baseURL}{prefix}/alarms）
VITE_API_V1_PREFIX=/v1

# GateAI 设置页 Mock 降级（开发建议 true；联调真实后端时设 false）
# VITE_GATEAI_MOCK_FALLBACK=true

# 生产示例
# VITE_API_BASE_URL=http://47.108.169.152:8089/api
