# 复制为 .env.development 或 .env.production 后按需修改



# API 根路径（开发：/api + Vite 代理；生产：完整地址如 http://host:port/api）

VITE_API_BASE_URL=/api



# v1 接口前缀（告警/调度/互锁等：GET {baseURL}{prefix}/alarms）

# 注意：模型研判（/settings/ai/*）不走 v1，见 src/api/settings.ts

VITE_API_V1_PREFIX=/v1



# 开发环境 — Vite 代理目标（仅 dev 使用，改后需重启 npm run dev）

# VITE_DEV_API_PROXY=http://47.108.169.152:8089

# 本机后端：VITE_DEV_API_PROXY=http://localhost:8000



# 生产示例

# VITE_API_BASE_URL=http://47.108.169.152:8089/api

# 演示联调：生产也走闸门对齐（全孔在线、目标=当前），与 npm run dev 表现一致
# VITE_DEMO_GATE_ALIGN=true



# Laravel Reverb WebSocket（可选）

# VITE_REVERB_APP_KEY=

# VITE_REVERB_HOST=localhost

# VITE_REVERB_PORT=8080

# VITE_REVERB_SCHEME=http

